# executive-job-ops environment configuration
# Copy this file to .env and fill in your values

# ── Required ──────────────────────────────────────────────
# Get a free key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# ── Optional (defaults work fine) ─────────────────────────
# Where resumes are watched (relative to project root)
RESUME_FOLDER=./resumes

# Database location
DATABASE_URL=sqlite:///./executive_job_ops.db

# Backend port
BACKEND_PORT=8000

# Frontend port
FRONTEND_PORT=3000

# OpenAI model (gpt-4o-mini is cheapest, gpt-4o is most accurate)
OPENAI_MODEL=gpt-4o-mini

# Secret key for session signing (change this for production)
SECRET_KEY=change-me-to-a-random-string-in-production

# ── Advanced (leave blank unless you know what you're doing) ──
# Use a local LLM instead of OpenAI (e.g. http://localhost:11434/v1)
# LOCAL_LLM_URL=
# LOCAL_LLM_MODEL=llama3
